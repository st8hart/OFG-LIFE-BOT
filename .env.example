# ============================
# VIVID LIFE BOT - CONFIG
# ============================
# Copy this file to .env and fill in your values

# Get from: https://discord.com/developers/applications
# Your Bot Token (keep this SECRET - never share it)
DISCORD_TOKEN=your_bot_token_here

# Your Application/Client ID
CLIENT_ID=your_client_id_here

# The Guild (Server) ID where you want to deploy commands
GUILD_ID=your_guild_id_here

# Channel ID where sales announcements get posted
SALES_CHANNEL_ID=your_sales_channel_id_here

# Channel ID where leaderboards get posted (can be same as above)
LEADERBOARD_CHANNEL_ID=your_leaderboard_channel_id_here

# Monthly team goal in dollars (no commas)
MONTHLY_GOAL=200000
